  "workflowMeta": {
    "stateMachine": ["pending", "active", "gated", "completed", "failed", "paused", "aborted"],
    "variants": {
      "small": "Lightweight path: skip unnecessary gates, no estimation huddle, start immediately. Auto-approves final gate if DoD is met. No tracking (no team.json, no budget.md). Compressed handoff (4 sections).",
      "full": "Standard path: all gates, estimation huddle, token-budget approval. Full tracking. User approves all gates."
    },
    "optimizations": {
      "auto-approve": "Small variant final gate auto-approved when all DoD items pass. No user interaction needed.",
      "skip-tracking": "Small variants skip team.json and budget.md. Phase states tracked in memory only.",
      "compressed-handoff": "Small variant handoffs use 4 sections: Summary, Outputs, Issues, Next.",
      "auto-detect-conditions": "Lead auto-detects conditions from task description. User can override.",
      "batch-delegation": "Parallel phases delegated in a single turn. Phases run concurrently.",
      "auto-resume": "Lead auto-resumes from last completed phase on 'continue' or 'resume'."
    },
    "conditions": {
      "regulated": "Adds compliance phase and atlas-compliance role",
      "data-changes": "Adds atlas-data-eng and atlas-dba roles",
      "security-sensitive": "Adds security-review phase and atlas-security role",
      "security-impacting": "Adds security-review phase and atlas-security role",
      "technical-deep-dive": "Adds atlas-architect role"
    },
    "autoDetect": {
      "security-sensitive": ["auth", "payment", "secret", "token", "credential"],
      "regulated": ["GDPR", "SOC2", "ISO", "compliance", "regulated"],
      "data-changes": ["pipeline", "data model", "analytics", "SQL", "query"]
    },
    "gates": {
      "requirements": "Requirements → Design (full only)",
      "design": "Design → Implementation (full only)",
      "final": "Implementation → Delivery (auto-approve if small)",
      "scope": "Scoping → Audit (security-audit only)",
      "research": "Research → Proposal (discovery only)"
    },
    "transitions": {
      "pending→active": "Lead delegates to role",
      "active→gated": "Role returns handoff",
      "gated→completed": "User approves gate (or auto-approve if small)",
      "gated→failed": "Gate criteria not met",
      "active→failed": "Role fails or model exhausted",
      "any→aborted": "User or lead cancels",
      "active→paused": "Scope change detected",
      "paused→active": "Re-evaluation complete, resume",
      "paused→aborted": "Re-evaluation determines restart needed"
    }
  },
  "tiers": {
    "premium": {
      "label": "Premium",
      "capabilities": ["deep-reasoning", "long-context", "complex-planning"],
      "description": "For gate roles requiring careful analysis: architect, security, reviewer, enterprise architect, cloud, compliance.",
      "modelHints": {
        "cursor": "claude-opus-4-8-thinking-high",
        "claude-code": "opus",
        "opencode": "anthropic/claude-opus-4",
        "vscode-copilot": "gpt-4o",
        "antigravity": "gemini-3-pro",
        "windsurf": "anthropic/claude-opus-4"
      }
    },
    "standard": {
      "label": "Standard",
      "capabilities": ["balanced", "general-purpose"],
      "description": "For orchestrator and everyday specialist work: lead, PM, BA, UX, QA, DevOps, maintenance, and enterprise specialists.",
      "modelHints": {
        "cursor": "composer-2.5",
        "claude-code": "sonnet",
        "opencode": "anthropic/claude-sonnet-4",
        "vscode-copilot": "gpt-4o-mini",
        "antigravity": "gemini-2.5-flash",
        "windsurf": "anthropic/claude-sonnet-4"
      }
    },
    "fast": {
      "label": "Fast",
      "capabilities": ["high-volume", "low-latency"],
      "description": "For implementation-heavy and documentation roles: dev, docs, data analyst.",
      "modelHints": {
        "cursor": "composer-2",
        "claude-code": "haiku",
        "opencode": "anthropic/claude-haiku-3.5",
        "vscode-copilot": "gpt-3.5-turbo",
        "antigravity": "gemini-2.5-flash",
        "windsurf": "anthropic/claude-haiku-3.5"
      }
    }
  },
  "delegation": {
    "protocol": "artifact-based",
    "requires": ["spawn-subagent", "pass-context", "collect-artifact"],
    "maxDepth": "varies-by-ide",
    "description": "Roles communicate through structured handoff artifacts, not shared chat. The orchestrator spawns specialists with self-contained briefs and collects their output artifacts."
  },
  "dataHome": {
    "envVar": "ATLAS_DATA_DIR",
    "default": "~/.atlas/data",
    "description": "Central directory for run artifacts, team manifests, gates, and budgets."
  },
  "knowledgeHome": {
    "envVar": "ATLAS_KNOWLEDGE_DIR",
    "default": "~/.atlas/knowledge",
    "description": "Shared team knowledge base. Roles read lessons before acting and append proposals after."
  },
  "lite": {
    "description": "Stripped-down mode for 3B-8B models with 8K context windows. ~1,100 token system prompt vs ~6,300 in full mode.",
    "contextWindow": "8K",
    "rules": "lite/rules/",
    "agents": "lite/agents/",
    "workflows": "lite/workflows/",
    "skills": "lite/skills/",
    "knowledge": "knowledge/",
    "knowledgeNote": "Knowledge files shared with full mode. Load only Quick Reference sections when possible.",
    "tokenBudget": {
      "systemPrompt": "~1,100 tokens",
      "remainingForTask": "~6,900 tokens"
    },
    "differences": [
      "atlas-core: 5 imperative rules, no meta-cognitive instructions",
      "handoff: 4-section format only (Summary, Outputs, Issues, Next)",
      "workflows: max 4 phases, inline conditions, no state machine",
      "state tracked in state.md (not team.json)",
      "no estimation huddle or budget tracking",
      "lead loads only: atlas-core, handoff-protocol, atlas-lead-orchestration, team-charter"
    ]
  }
}
